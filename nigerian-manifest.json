{
  "id": "nigerian",
  "name": "Nigerian Food Theme",
  "flag": "🇳🇬",
  "description": "The complete collection of Nigerian dish packs — from everyday meals to party favourites. All dishes are always visible. Cook your way through each path to unlock the next.",
  "version": 4,
  "theme_notes": {
    "browsing": "All dishes in this theme are always visible and accessible. No dish is hidden.",
    "progression": "Progression lives inside each dish path — not at the pack or theme level.",
    "unlocking": "Beginner path is always unlocked. Achieve a B rating or above on Beginner to unlock Intermediate. Achieve an A rating or above on Intermediate to unlock Advanced.",
    "mastery": "Achieve an S rating on any path to earn the Master achievement on that path.",
    "legend": "Achieve an S rating on the highest available path of a dish after completing the full journey to earn Dish Legend status on that dish."
  },
  "path_unlock_rules": {
    "beginner_to_intermediate": {
      "minRating": "B",
      "description": "Achieve a B rating or above on the Beginner path to unlock Intermediate"
    },
    "intermediate_to_advanced": {
      "minRating": "A",
      "description": "Achieve an A rating or above on the Intermediate path to unlock Advanced"
    }
  },
  "achievement_rules": {
    "master": {
      "trigger": "S rating on any path",
      "description": "Achieve an S rating on any path to earn the Master achievement on that path",
      "display": "Quiet permanent stamp on the path card — no popup"
    },
    "dish_legend": {
      "trigger": "S rating on highest available path after completing full journey",
      "description": "Achieve S on the highest available path having cooked all paths on the dish",
      "display": "Permanent mark on the dish card in the pack browser — no popup"
    }
  },

